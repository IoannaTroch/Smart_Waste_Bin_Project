{
  "@context": {
    "@vocab": "https://schema.org/",
    "sosa": "http://www.w3.org/ns/sosa/",
    "ssn": "http://www.w3.org/ns/ssn/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "pipeline": "https://github.com/IoannaTroch/Smart_Waste_Bin_Project/blob/main/docs/ontology.md#",
    "mountedOn": { "@id": "ssn:isPropertyOf", "@type": "@id" },
    "deployedIn": { "@id": "sosa:hasFeatureOfInterest", "@type": "@id" },
    "gpioPin": { "@id": "pipeline:gpioPin", "@type": "xsd:integer" },
    "detectionRangeMeters": { "@id": "pipeline:detectionRangeMeters", "@type": "xsd:float" },
    "detectionAngleDegrees": { "@id": "pipeline:detectionAngleDegrees", "@type": "xsd:float" },
    "cooldownSeconds": { "@id": "pipeline:cooldownSeconds", "@type": "xsd:float" },
    "triggerMode": { "@id": "pipeline:triggerMode", "@type": "xsd:string" },
    "installationDate": { "@id": "schema:dateCreated", "@type": "xsd:date" },
    "status": "schema:status"
  },
  "@id": "urn:dev:team-10:pir-01",
  "@type": "sosa:Sensor",
  "name": "HC-SR501 PIR Motion Sensor — Bin A",
  "description": "HC-SR501 passive infrared motion sensor mounted on wastebin BIN-A-101 in Lab Room 101. Detects infrared radiation emitted by warm bodies passing through its Fresnel lens detection cone. Operated in repeatable-trigger mode (H) with a software cooldown enforced by the pipeline.",
  "manufacturer": "Various (LHI778 probe + BISS0001 IC)",
  "model": "HC-SR501",
  "serialNumber": "pir-01",
  "sosa:observes": {
    "@type": "sosa:ObservableProperty",
    "name": "Motion Presence",
    "description": "Detects whether a warm body is moving within the PIR detection cone by sensing changes in passive infrared radiation."
  },
  "gpioPin": 17,
  "detectionRangeMeters": 7.0,
  "detectionAngleDegrees": 120.0,
  "cooldownSeconds": 2.0,
  "triggerMode": "H",
  "operatingVoltageMin": 4.5,
  "operatingVoltageMax": 20.0,
  "operatingTempMinC": -20,
  "operatingTempMaxC": 80,
  "indoorUse": true,
  "mountedOn": "urn:wastebin:bin-a-101",
  "deployedIn": "urn:env:lab-room-101",
  "installationDate": "2026-01-15",
  "status": "active"
}